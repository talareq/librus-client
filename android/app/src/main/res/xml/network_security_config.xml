<?xml version="1.0" encoding="utf-8"?>
<!--
  Librus bywa przekierowywany na http:// na hostach *.librus.pl (redirect po stronie serwera).
  WebView na Androidzie 9+ blokuje cleartext (ERR_CLEARTEXT_NOT_PERMITTED).
  Dopuszczamy cleartext tylko dla znanych hostów dziennika — nie dla całej domeny (ograniczenie MITM).
  W TypeScript wymuszamy https tam, gdzie generujemy URL (librus-auth.ensureHttpsLibrusUrl).
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">synergia.librus.pl</domain>
        <domain includeSubdomains="false">wiadomosci.librus.pl</domain>
        <domain includeSubdomains="false">portal.librus.pl</domain>
        <domain includeSubdomains="false">api.librus.pl</domain>
        <domain includeSubdomains="false">dziennik.librus.pl</domain>
        <domain includeSubdomains="false">konto.librus.pl</domain>
    </domain-config>
</network-security-config>
